# LLM 提供商：qwen（通义千问）或 glm（智谱）
LLM_PROVIDER=qwen

# 通义千问（阿里云 DashScope）
DASHSCOPE_API_KEY=your-dashscope-api-key-here
QWEN_MODEL=qwen3-32b
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# GLM (智谱)
ZHIPUAI_API_KEY=your-zhipu-api-key-here
GLM_MODEL=glm-4.7-flash

# Agent 服务
AGENT_HOST=0.0.0.0
AGENT_PORT=8090

# mall_agent 库
AGENT_DB_HOST=localhost
AGENT_DB_PORT=3308
AGENT_DB_USER=root
AGENT_DB_PASSWORD=111111
AGENT_DB_NAME=mall_agent

# mall 业务库（售后查询、RAG 同步、会员查询）
MALL_DB_HOST=localhost
MALL_DB_PORT=3308
MALL_DB_USER=root
MALL_DB_PASSWORD=111111
MALL_DB_NAME=mall

# mall-portal API
MALL_PORTAL_BASE_URL=http://localhost:8085

# JWT（与 mall-portal 一致）
JWT_SECRET=mall-portal-secret
JWT_TOKEN_HEAD=Bearer 

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=mall_product_knowledge

# 本地 Embedding 模型
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
